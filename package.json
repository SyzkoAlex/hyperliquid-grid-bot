{
    "name": "hyperliquid-grid-bot",
    "version": "1.0.0",
    "description": "Grid Trading Bot for Hyperliquid",
    "author": "Aleksey Syzko",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/src/main.js",
        "start:dev": "node --watch -r @swc-node/register src/main.ts",
        "start:trading-bot": "APP_TYPE=trading-bot node dist/src/main.js",
        "start:trading-bot:dev": "APP_TYPE=trading-bot node --watch -r @swc-node/register src/main.ts",
        "start:telegram-ctrl": "APP_TYPE=telegram-ctrl node dist/src/main.js",
        "start:telegram-ctrl:dev": "APP_TYPE=telegram-ctrl node --watch -r @swc-node/register src/main.ts",
        "start:all-in-one": "APP_TYPE=all-in-one node dist/src/main.js",
        "start:all-in-one:dev": "APP_TYPE=all-in-one node --watch -r @swc-node/register src/main.ts",
        "lint": "eslint \"src/**/*.ts\" --quiet",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "test": "vitest run",
        "test:unit": "vitest run --config vitest.unit.config.ts",
        "test:unit:watch": "vitest --config vitest.unit.config.ts",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "db:push": "drizzle-kit push",
        "typecheck": "tsc --noEmit",
        "audit:pnpm": "pnpm audit --audit-level high",
        "qa:check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build && pnpm test:unit && pnpm audit:pnpm",
        "prepare": "husky"
    },
    "dependencies": {
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.3.0",
        "@nestjs/platform-express": "^10.3.0",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/terminus": "^10.2.0",
        "axios": "^1.13.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "decimal.js": "^10.4.3",
        "dotenv": "^16.4.1",
        "drizzle-orm": "^0.33.0",
        "hyperliquid": "^1.7.7",
        "js-yaml": "^4.1.0",
        "pg": "^8.11.3",
        "pino": "^8.17.2",
        "pino-http": "^9.0.0",
        "pino-pretty": "^11.0.0",
        "prom-client": "^15.1.0",
        "redis": "^4.6.12",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1",
        "telegraf": "^4.16.3",
        "uuid": "^9.0.1",
        "viem": "^2.43.3",
        "ws": "^8.16.0",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.10",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.8",
        "@testcontainers/postgresql": "^11.11.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.10.9",
        "@types/uuid": "^9.0.7",
        "@types/ws": "^8.5.10",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "@vitest/coverage-v8": "^1.2.0",
        "drizzle-kit": "^0.24.0",
        "eslint": "^9.0.0",
        "globals": "^16.5.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.2.0",
        "prettier": "^3.2.4",
        "testcontainers": "^11.11.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "unplugin-swc": "^1.5.9",
        "vitest": "^1.2.0"
    },
    "pnpm": {
        "overrides": {
            "qs": ">=6.14.1"
        }
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=8.0.0"
    },
    "packageManager": "pnpm@8.15.0"
}
