{
    "name": "hyperliquid-grid-bot",
    "version": "1.0.0",
    "description": "Grid Trading Bot for Hyperliquid",
    "author": "Aleksey Syzko",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "start": "node dist/src/main.js",
        "start:dev": "node --watch -r @swc-node/register src/main.ts",
        "lint": "eslint \"src/**/*.ts\" --quiet",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "test": "vitest run",
        "test:unit": "vitest run --config vitest.unit.config.ts",
        "test:unit:watch": "vitest --config vitest.unit.config.ts",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "db:push": "drizzle-kit push",
        "typecheck": "tsc --noEmit",
        "audit:pnpm": "pnpm audit --audit-level high",
        "qa:check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build && pnpm test:unit && pnpm audit:pnpm",
        "prepare": "husky"
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.1.3",
        "@nestjs/common": "^11.1.19",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.19",
        "@nestjs/platform-express": "^11.1.19",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/terminus": "^11.1.1",
        "axios": "^1.15.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.4",
        "decimal.js": "^10.6.0",
        "dotenv": "^16.6.1",
        "drizzle-orm": "^0.45.2",
        "js-yaml": "^4.1.1",
        "pg": "^8.20.0",
        "pino": "^8.21.0",
        "pino-http": "^9.0.0",
        "prom-client": "^15.1.3",
        "redis": "^4.7.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "telegraf": "^4.16.3",
        "uuid": "^9.0.1",
        "viem": "^2.48.4",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.19",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.32",
        "@testcontainers/postgresql": "^11.14.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.19.39",
        "@types/pg": "^8.20.0",
        "@types/uuid": "^9.0.8",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "@vitest/coverage-v8": "^3.2.4",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "pino-pretty": "^11.3.0",
        "prettier": "^3.8.3",
        "testcontainers": "^11.14.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "unplugin-swc": "^1.5.9",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "overrides": {
            "qs": ">=6.14.1",
            "minimatch": ">=10.2.1",
            "multer": ">=2.1.1",
            "lodash": ">=4.18.0",
            "esbuild": ">=0.25.0",
            "undici": ">=7.24.0",
            "flatted": ">=3.4.0",
            "file-type": ">=21.3.2",
            "vite": "^6.4.2",
            "protobufjs": ">=7.5.5"
        }
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=8.0.0"
    },
    "packageManager": "pnpm@8.15.0"
}
