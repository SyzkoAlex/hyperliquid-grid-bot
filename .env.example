# Hyperliquid Grid Bot — Environment Template
# Copy to .env and fill in REQUIRED values.
# See docs/QUICKSTART.md for setup instructions.

# === App ===
APP_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0

# === Database ===
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=db-user
DATABASE_PASSWORD=db-password   # Change for any non-local deployment
DATABASE_NAME=hyperliquid_grid_bot
DATABASE_POOL_SIZE=10

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# === Hyperliquid ===
HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_TESTNET=true
HYPERLIQUID_AGENT_KEY_ENCRYPTION_KEY=   # REQUIRED — generate with: openssl rand -hex 32
HYPERLIQUID_REQUEST_TIMEOUT=30000
HYPERLIQUID_MIN_ORDER_NOTIONAL=10
HYPERLIQUID_SELL_SIZE_BUFFER=0.005

# === Telegram ===
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=   # REQUIRED — get from @BotFather on Telegram
TELEGRAM_ALLOWED_USER_ID=   # RECOMMENDED — your numeric Telegram user ID, restricts the bot to you only
TELEGRAM_BOT_LOCK_TTL_MS=60000

# === Orders ===
ORDERS_POLL_INTERVAL_MS=2000
ORDERS_RECOVERY_INTERVAL_MS=600000
ORDERS_PENDING_CLEANUP_THRESHOLD_MS=300000
ORDERS_SYNC_LOCK_TTL_MS=30000
ORDERS_RESTORE_LOCK_TTL_MS=60000

# === Tokens ===
TOKENS_TOP_SIZE=10
TOKENS_REFRESH_INTERVAL_MS=3600000
TOKENS_CACHE_TTL_SECONDS=86400
TOKENS_LOCK_TTL_MS=60000

# === Swap ===
SWAP_INITIAL_SLIPPAGE_CAP_PCT=0.005
SWAP_RETRY_SLIPPAGE_CAP_PCT=0.015

# === Stop Loss ===
STOP_LOSS_INITIAL_SLIPPAGE_CAP_PCT=0.01
STOP_LOSS_RETRY_SLIPPAGE_CAP_PCT=0.02
STOP_LOSS_CONFIRM_DURATION_MS=30000
STOP_LOSS_PENETRATION_PCT=0.002
STOP_LOSS_BREACH_TTL_SECONDS=300

# === Logging ===
LOG_LEVEL=info
LOG_PRETTY=false

# === Metrics ===
METRICS_ENABLED=true
